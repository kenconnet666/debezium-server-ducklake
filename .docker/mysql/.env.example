# 复制为 .env 后按需修改(docker compose 自动读取;.env 已被 .gitignore 排除)。
# 不建 .env 时全部取 changeme/admin 默认值——仅限本机体验,对外部署必须覆盖。

# 源库 MySQL root 与 dbuser_cdc 共用密码(initdb 一次性写死,改动需清 mysql/data 重建)
MYSQL_PASSWORD=changeme

# 元空间 lake_admin 密码(同上,改动需清 catalog-pg/data 重建)
CATALOG_PASSWORD=changeme

# rustfs S3 凭据(管理控制台 http://127.0.0.1:19011 同账号)
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=changeme
